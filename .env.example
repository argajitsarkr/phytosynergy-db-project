# ============================================================
# PhytoSynergyDB — Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file to .env  (it will NOT be committed to git)
#      cp .env.example .env
#   2. Fill in every value below
#   3. Never commit the .env file itself
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=phytosynergy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_use_a_long_random_password

# --- Django ---
# Generate a secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_real_secret_key

# Set to 0 for production, 1 only for local development
DEBUG=0

# Comma-separated list of allowed hostnames / IP addresses
# e.g.  192.168.1.100,phytosynergydb.example.com
ALLOWED_HOSTS=YOUR_SERVER_IP_OR_DOMAIN

# Only needed if the site is served over HTTPS (leave blank for HTTP-only)
# e.g.  https://phytosynergydb.example.com
CSRF_TRUSTED_ORIGINS=
